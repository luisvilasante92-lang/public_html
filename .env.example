# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-in-production

# Database (SQLite — dev; MySQL/PostgreSQL — production)
# SQLite: sqlite:///instance/lksystem.db
# MySQL: mysql+pymysql://user:password@localhost:3306/lksystem
# PostgreSQL: postgresql://user:password@localhost:5432/lksystem
DATABASE_URL=sqlite:///instance/lksystem.db

# External auth service (поддомены luisv-records.ru: auth — вход, lk — ЛК)
AUTH_SERVICE_URL=https://auth.luisv-records.ru
AUTH_CALLBACK_URL=https://lk.luisv-records.ru/auth/callback

# Smart links domain
SMART_LINK_BASE_URL=https://lk.luisv-records.ru/link

# Основной домен (вход: https://auth.luisv-records.ru, ЛК: https://lk.luisv-records.ru)
# APPLICATION_ROOT_URL=https://luisv-records.ru

# S3 Storage (optional)
S3_URL=https://s3.luisv-records.ru
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# Email (SMTP) — Beget: порт 587 не поддерживается. 2525 (STARTTLS) или 465 (SSL)
MAIL_SERVER=smtp.beget.com
MAIL_PORT=2525
MAIL_USE_TLS=true
# Для порта 465: MAIL_PORT=465, MAIL_USE_TLS=false, MAIL_USE_SSL=true
# MAIL_USE_SSL=false
MAIL_USERNAME=noreply@luisv-records.ru
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER=noreply@luisv-records.ru
# Email поддержки (не менять при смене домена, если указан support@lvr-music-publishing.ru)
SUPPORT_EMAIL=support@lvr-music-publishing.ru

# SMS Aero (коды авторизации по SMS). Документация: https://smsaero.ru/integration/documentation/api/
SMSAERO_EMAIL=your-email@smsaero.ru
SMSAERO_API_KEY=
# Подпись: SMS Aero (встроенная) или ваша одобренная в кабинете smsaero.ru
SMSAERO_SIGN=SMS Aero
# При ошибке SSL (CERTIFICATE_VERIFY_FAILED) на хостинге: SMSAERO_SSL_VERIFY=false
# SMSAERO_SSL_VERIFY=false

# Upload limits (in bytes)
MAX_COVER_SIZE=10485760
MAX_TRACK_SIZE=104857600
MAX_AVATAR_SIZE=5242880
MAX_NEWS_COVER_SIZE=5242880
MAX_FINANCE_FILE_SIZE=10485760
MAX_CONTRACT_SIZE=10485760
